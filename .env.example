# ============================================================
# QA-ORCHESTRATOR — Environment Variables Template
# NEVER commit the real .env file
# ============================================================

# ── Environment ──────────────────────────────────────────────
APP_ENV=homologacao          # development | homologacao | production
BASE_URL=https://app.example.com

# ── Claude AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # Obtain from console.anthropic.com

# ── PostgreSQL (Bug/Knowledge DB) ────────────────────────────
DATABASE_URL=postgresql://qauser:qapass@localhost:5432/qa_orchestrator

# ── Redis (Agent state cache) ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Qdrant (Vector memory) ───────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=qa_knowledge

# ── GitHub Integration ───────────────────────────────────────
GITHUB_TOKEN=                # Personal access token (repo + pr scope)
GITHUB_OWNER=
GITHUB_REPO=

# ── Secrets Backend ──────────────────────────────────────────
SECRETS_BACKEND=vault        # vault | aws | azure
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
# AWS_REGION=us-east-1
# AZURE_VAULT_URL=

# ── Security Tools ───────────────────────────────────────────
ZAP_API_URL=http://localhost:8090
ZAP_API_KEY=

# ── Reporting ────────────────────────────────────────────────
ALLURE_RESULTS_DIR=allure-results
EVIDENCE_DIR=evidence
REPORTS_DIR=reports

# ── Test Data ────────────────────────────────────────────────
TEST_DATA_LOCALE=pt_BR
