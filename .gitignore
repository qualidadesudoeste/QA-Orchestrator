# Dependencies
node_modules/
.pnp
.pnp.js

# Build
dist/
build/

# Environment — NEVER commit real credentials
.env
.env.local
.env.*.local

# Playwright auth state (contains session tokens — never commit)
playwright/.auth/

# Test outputs / evidência (screenshots de telas internas — nunca commitar)
allure-results/
allure-report/
artifacts/
reports/*.json
reports/*.html
playwright-report/
test-results/

# Exports de sistemas Maker (estrutura/SQL/regras internas — nunca commitar)
*.FRZ
*.frz
*.jar
*.jar.zip

# Base de conhecimento: versiona o .md (conhecimento), ignora binário/sensível
systems/**/screenshots/
systems/**/executions/
systems/**/system_info/credentials.md

# ── CONHECIMENTO DE CLIENTE = CONFIDENCIAL, SÓ LOCAL (nunca commitar) ──
# Regra de negócio do cliente (tabelas, SQL, exports Maker, URLs, menus,
# arquitetura, padrões aprendidos) fica APENAS no disco. O Git versiona o
# motor do agente e a estrutura de pastas (.gitkeep), não o conhecimento.
systems/**/system_info/
systems/**/knowledge/
systems/**/learned_patterns/
systems/**/*.xml
# Log operacional/sessão com detalhe de cliente — só local
NOTES.local.md
CLAUDE.local.md
# Evidência é SEMPRE por sistema (systems/<CODE>/evidences/...): versiona a
# estrutura (.gitkeep) mas nunca os binários/telas internas.
systems/**/evidences/**/*.png
systems/**/evidences/**/*.jpg
systems/**/evidences/**/*.jpeg
systems/**/evidences/**/*.webm
systems/**/evidences/**/*.zip
systems/**/evidences/**/*.json
systems/**/evidences/**/*.feature
systems/**/evidences/**/*.md

# Prisma
prisma/migrations/

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Secrets
*.pem
*.key
*.cert
secrets/
vault-token

# Perfis aprendidos = config por sistema (hosts/seletores) — só local
data/profiles/*.json
