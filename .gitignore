# Dependencies
node_modules/
.pnp
.pnp.js

# Build
dist/
build/

# Environment — NEVER commit real credentials
.env
.env.local
.env.*.local

# Playwright auth state (contains session tokens — never commit)
playwright/.auth/

# Test outputs / evidência (screenshots de telas internas — nunca commitar)
allure-results/
allure-report/
artifacts/
reports/*.json
reports/*.html
playwright-report/
test-results/

# Exports de sistemas Maker (estrutura/SQL/regras internas — nunca commitar)
*.FRZ
*.frz
*.jar
*.jar.zip

# Base de conhecimento: versiona o .md (conhecimento), ignora binário/sensível
systems/**/screenshots/
systems/**/executions/
systems/**/system_info/credentials.md
# Evidência é SEMPRE por sistema (systems/<CODE>/evidences/...): versiona a
# estrutura (.gitkeep) mas nunca os binários/telas internas.
systems/**/evidences/**/*.png
systems/**/evidences/**/*.jpg
systems/**/evidences/**/*.jpeg
systems/**/evidences/**/*.webm
systems/**/evidences/**/*.zip
systems/**/evidences/**/*.json
systems/**/evidences/**/*.feature

