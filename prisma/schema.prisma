generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BugReport {
  id                   String    @id @default(cuid())
  title                String
  category             String
  module               String
  path                 String
  description          String
  actualResult         String
  expectedResult       String
  steps                String    // JSON array
  severity             String
  priority             String
  risk                 String
  evidencePaths        String    // JSON array
  possibleCause        String?
  commitHash           String?
  prNumber             String?
  version              String?
  isRecurrence         Boolean   @default(false)
  previousOccurrenceId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([module])
  @@index([category])
  @@index([isRecurrence])
}

model KnowledgeEntry {
  id            String   @id @default(cuid())
  module        String   @unique
  flowType      String   // CRITICAL | STABLE | PROBLEMATIC
  description   String
  businessRules String   // JSON array
  knownIssues   String   // JSON array
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TestRun {
  id              String   @id @default(cuid())
  environment     String
  scope           String
  commitHash      String?
  prNumber        String?
  totalScenarios  Int      @default(0)
  passed          Int      @default(0)
  failed          Int      @default(0)
  skipped         Int      @default(0)
  bugsFound       Int      @default(0)
  riskLevel       String?
  reportPath      String?
  startedAt       DateTime @default(now())
  finishedAt      DateTime?

  @@index([environment])
  @@index([startedAt])
}
